{
  "name": "@mimrlabs/plugin-claw3d",
  "version": "0.3.0",
  "description": "Paperclip launcher tile for the Claw3D 3D office app.",
  "license": "MIT",
  "type": "module",
  "private": true,
  "exports": {
    ".": "./src/index.ts"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "tsc && node ./scripts/build-ui.mjs",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "dev:ui": "node ./scripts/build-ui.mjs --watch"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "file:./.paperclip-sdk/plugins/sdk",
    "@paperclipai/shared": "file:./.paperclip-sdk/shared"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  },
  "peerDependencies": {
    "react": ">=18"
  }
}
