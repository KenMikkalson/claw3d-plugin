node_modules/
dist/
*.tsbuildinfo
*.log
.env
.env.*

# Claude Code session data
.claude/

# Snapshotted Paperclip SDK — tracked so the repo builds without a Paperclip
# workspace, but excluded from package tarballs. The SDK ships pre-built
# (no tsconfig, no build script on the consumer side) so we keep `dist/`
# tracked here even though the top-level `dist/` rule above would exclude it.
.paperclip-sdk/**/node_modules/
!.paperclip-sdk/**/dist/
!.paperclip-sdk/**/dist/**

# Local reference copy of upstream example plugins — useful when authoring,
# not shipped with the plugin.
.reference/
